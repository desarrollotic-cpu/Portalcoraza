NODE_ENV=development
PORT=3000

# Supabase PostgreSQL
# RECOMENDADO (Windows / IPv4): Session pooler. Copia el host EXACTO del dashboard
# (Settings > Database > Connection string > Session pooler); puede ser aws-0 o aws-1.
# Reemplaza [PASSWORD] por la contraseña real de la base de datos.
DATABASE_URL=postgresql://postgres.duxpqkldgdnfcabpkogl:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Alternativa (conexión directa): suele fallar en Windows por IPv6 (ENOTFOUND). Usar solo si el pooler no está disponible.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.duxpqkldgdnfcabpkogl.supabase.co:5432/postgres

SUPABASE_URL=https://duxpqkldgdnfcabpkogl.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_20qs6z_...
SUPABASE_PROJECT_REF=duxpqkldgdnfcabpkogl

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Clave larga (>=16) para recuperar admin desde login si olvidó la contraseña.
# También puedes usar: npm run reset:admin-password
ADMIN_RECOVERY_SECRET=change-me-admin-recovery-secret-min-16

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_SIGNATURE_BUCKET=delivery-signatures

# Incluye ambos orígenes para evitar el problema de CORS al abrir con 127.0.0.1
CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200

SEED_ADMIN_EMAIL=admin@corazaseguridadcta.com
SEED_ADMIN_PASSWORD=Coraza2026!
