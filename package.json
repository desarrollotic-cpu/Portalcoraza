{
  "name": "system-coraza",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma administrativa y operativa - vigilancia y seguridad privada",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev -w @coraza/api",
    "api:build": "npm run build -w @coraza/api",
    "web:dev": "npm run start -w @coraza/web",
    "web:build": "npm run build -w @coraza/web",
    "install:all": "npm install",
    "db:setup": "npm run db:setup -w @coraza/api",
    "db:keepalive": "npm run db:keepalive -w @coraza/api",
    "reset:admin-password": "npm run reset:admin-password -w @coraza/api"
  },
  "engines": {
    "node": ">=20"
  }
}
